# CalBol Environment Variables
# Copy this file to .env and fill in your values

# Django
SECRET_KEY=your-secret-key-here-generate-a-random-string
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Database (PostgreSQL - Supabase)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# OpenAI
OPENAI_API_KEY=sk-...

# Resend (Email)
RESEND_API_KEY=re_...

# WhatsApp Cloud API (Meta Business)
# Get these from Meta Developer Portal: https://developers.facebook.com/
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_APP_SECRET=your-app-secret
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Email Webhook Security (REQUIRED for email integration)
# SendGrid webhook verification key (found in SendGrid dashboard -> Settings -> Inbound Parse)
SENDGRID_WEBHOOK_KEY=your-sendgrid-webhook-verification-key
# Mailgun API key (found in Mailgun dashboard -> Settings -> API Keys)
MAILGUN_API_KEY=your-mailgun-api-key

# CORS (for API access from frontend)
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Sentry Error Monitoring (optional - leave empty to disable)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=calbol@1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
